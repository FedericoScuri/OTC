# Copiá este archivo como `.env`. El `.env` está en .gitignore (NUNCA subir claves).

# Puerto del backend
PORT=4000

# RPC del nodo (Hardhat local por defecto)
RPC_URL=http://127.0.0.1:8545

# --- Claves para la demo LOCAL ---
# Son las cuentas deterministas de Hardhat (#0 y #1). En testnet/prod se
# reemplazan por claves de PRUEBA propias. Jamás usar una wallet con fondos reales.

# Cuenta del operador on-ramp (#0): mintea USDC de prueba al comprar (RF-D01).
ONRAMP_PRIVATE_KEY=0xac0974bec39a17e36ba4a6b4d238ff944bacb478cbed5efcae784d7bf4f2ff80

# Cuenta del proveedor (#1): publica paquetes al sincronizar el PMS (RF-B01).
PROVIDER_PRIVATE_KEY=0x59c6995e998f97a5a0044966f0945389dc9e86dae88c7a8412f4603b6b78690d

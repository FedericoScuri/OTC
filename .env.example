# Copiá este archivo como `.env` y completá los valores.
# El archivo `.env` está en .gitignore y NUNCA debe subirse al repo.

# Reporte de gas en los tests (true/false)
REPORT_GAS=false

# --- Solo para deploy en testnet/producción (no necesario para la demo local) ---
# RPC de Base Sepolia (ej: desde alchemy.com o infura.io)
BASE_SEPOLIA_RPC_URL=

# Clave privada de una wallet de PRUEBA (jamás una con fondos reales).
# Conseguí ETH de testnet gratis en un faucet de Base Sepolia.
PRIVATE_KEY=

# API key de BaseScan para verificar el código en el explorer (basescan.org > API Keys).
# Necesaria para `npm run verify:testnet`.
BASESCAN_API_KEY=
